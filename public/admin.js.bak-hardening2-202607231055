async function savePatchedPage(){
  const btn=$('#pedSaveBtn');if(btn)btn.disabled=true;
  
  const updates = [];
  for (const id of deletedBlocks) {
    const b = pageBlocks.find(x=>x.id===id);
    if (b && !b.isNew) updates.push({ id: b.id, orig: b.orig, delete: true });
  }

  const activeBlocks = pageBlocks.filter(b => !deletedBlocks.has(b.id));

  for (const b of activeBlocks) {
    const newVal = pageEdited[b.id]!==undefined ? pageEdited[b.id] : b.value;
    const newHref = b.type==='a' ? (pageEdited[b.id+'_href']!==undefined ? pageEdited[b.id+'_href'] : b.href) : undefined;
    
    if (b.isNew) {
      updates.push({
        id: b.id,
        type: b.type,
        isNew: true,
        newVal: newVal,
        newHref: newHref
      });
      continue;
    }
    
    const isValChanged = newVal !== undefined && newVal !== b.origVal;
    const isHrefChanged = b.type==='a' && newHref !== undefined && newHref !== b.href;
    
    if(isValChanged || isHrefChanged) {
      updates.push({ 
        id: b.id,
        orig: b.orig, origVal: b.origVal, 
        newVal: isValChanged ? newVal : undefined, 
        newHref: isHrefChanged ? newHref : undefined, 
        type: b.type
      });
    }
  }

  const reorderList = activeBlocks.map(b => b.id);
  if (!updates.length && (!reorderList || reorderList.length <= 1)){
    toast('Немає змін для збереження','i');if(btn)btn.disabled=false;return;
  }
  try{
    const payload = { blocks: updates };
    if (reorderList && reorderList.length > 1) payload.reorder = reorderList;
    const res=await api('PATCH',`/api/admin/page-patch?path=${encodeURIComponent(activePage)}`, payload);
    toast(`Збережено (${res.changed} змін) ✓`,'ok');
    
    const fresh=await api('GET',`/api/admin/page-extract?path=${encodeURIComponent(activePage)}`).catch(()=>null);
    if(fresh&&Array.isArray(fresh.blocks))pageBlocks=fresh.blocks;
    pageEdited={}; deletedBlocks.clear();
    refreshPreview();
    const pg=pages.find(p=>p.file===activePage);if(pg)pg.mtime=Date.now();
    // renderPagesUI rebuilds the whole editor DOM — without this the blocks
    // list snaps back to the top after every save
    const bodyEl=document.querySelector('.ped-body');const keepScroll=bodyEl?bodyEl.scrollTop:0;
    renderPagesUI();
    const nb=document.querySelector('.ped-body');if(nb)nb.scrollTop=keepScroll;
  }catch(e){toast('Помилка: '+e.message,'er');}
  finally{if(btn)btn.disabled=false;}
}
