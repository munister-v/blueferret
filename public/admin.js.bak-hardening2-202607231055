  const btn=$('#pgDialogSave'); if(btn)btn.disabled=true;
  try{
    let res;
    if(pgDialogMode==='new'){
      const title=$('#pgNewTitle')?.value?.trim();
      const slug=$('#pgNewSlug')?.value?.trim();
      if(!slug) return toast('Вкажіть URL','er');
      const tplEl=$('.pg-type.sel');
      const tpl=tplEl?.dataset.tpl||'blank';
      const copyFrom=tpl.startsWith('copy:')?tpl.slice(5):null;
      res=await api('POST','/api/admin/pages/create',{slug,title:title||slug,copyFrom});
    } else {
      const from=$('#pgCopyFrom')?.value;
      const slug=$('#pgCopySlug')?.value?.trim();
      if(!from||!slug) return toast('Заповніть всі поля','er');
      res=await api('POST','/api/admin/pages/duplicate',{from,slug});
    }
    pages=await api('GET','/api/admin/pages');
    closePgDialog();
    activePage=res.file; pageBlocks=[]; pageEdited={};
    const extr=await api('GET',`/api/admin/page-extract?path=${encodeURIComponent(res.file)}`).catch(()=>({blocks:[]}));
    pageBlocks=extr.blocks||[];
    toast(`Сторінку /${res.slug}/ створено ✓`,'ok');
    renderPagesUI();
  }catch(e){ if(e.message!=='unauth') toast('Помилка: '+e.message,'er'); }
  finally{ if(btn)btn.disabled=false; }
}
window.execPgAction=execPgAction;

async function deletePage(file){
  const pg=pages.find(p=>p.file===file);
  if(!pg||SYS_PAGES.has(file)){ toast('Системну сторінку не можна видалити','er'); return; }
  if(!confirm(`Видалити сторінку "${pg.path}"?\n\nЦе незворотно!`)) return;
  try{
    await api('DELETE',`/api/admin/pages/delete?path=${encodeURIComponent(file)}`);
    if(activePage===file){ activePage=null; pageBlocks=[]; pageEdited={}; }
    pages=await api('GET','/api/admin/pages');
    toast(`Сторінку "${pg.path}" видалено`,'ok');
    renderPagesUI();
  }catch(e){ if(e.message!=='unauth') toast('Помилка: '+e.message,'er'); }
}
async function duplicatePage(file){
  const slug=prompt('URL нової сторінки (slug):');
