}

// ── AUTH ──
function showLogin(){$('#loginPage').classList.remove('hidden');$('#appPage').classList.add('hidden');$('#pw').value='';setTimeout(()=>$('#pw').focus(),80);}
function showApp(){$('#loginPage').classList.add('hidden');$('#appPage').classList.remove('hidden');}

function togglePw(){const i=$('#pw');const b=$('#pwToggle');if(!i)return;if(i.type==='password'){i.type='text';b.textContent='🙈';}else{i.type='password';b.textContent='👁';}}
window.togglePw=togglePw;

$('#loginForm').addEventListener('submit',async e=>{
  e.preventDefault();$('#loginBtn').disabled=true;$('#loginErr').classList.add('hidden');
  const ctl=new AbortController();
  const tid=setTimeout(()=>ctl.abort(),15000);
  try{
    const r=await fetch('/api/admin/login',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',signal:ctl.signal,
      body:JSON.stringify({password:$('#pw').value,remember:$('#rememberMe')?.checked||false})});
    if(r.ok){
      if($('#rememberMe')?.checked)localStorage.setItem('bf_remember','1');
      await boot();
    }else{const j=await r.json().catch(()=>({}));$('#loginErr').textContent=j.error==='too_many_attempts'?'Забагато спроб — зачекайте 10 хв':'Невірний пароль';$('#loginErr').classList.remove('hidden');}
  }catch(err){
    $('#loginErr').textContent=err.name==='AbortError'?'Сервер відповідає занадто довго':'Сервер тимчасово недоступний';
    $('#loginErr').classList.remove('hidden');
  }finally{clearTimeout(tid);$('#loginBtn').disabled=false;}
});
// restore remember state
if(localStorage.getItem('bf_remember')==='1'&&$('#rememberMe'))$('#rememberMe').checked=true;

$('#logoutBtn').addEventListener('click',async()=>{
  await fetch('/api/admin/logout',{method:'POST'});
  localStorage.removeItem('bf_remember');
  showLogin();
});

