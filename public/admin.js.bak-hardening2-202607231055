async function quickToggleStatus(type,id,current){
  const next={published:'draft',draft:'published',archived:'published'}[current]||'published';
  try{
    if(type==='game'){await api('PUT',`/api/admin/games/${id}`,{status:next});games=await api('GET','/api/admin/games');}
    else{await api('PUT',`/api/admin/kik/${id}`,{status:next});kik=await api('GET','/api/admin/kik');}
    toast(`Статус → ${next}`);render();
  }catch(e){toast(e.message,'er');}
}
window.quickToggleStatus=quickToggleStatus;
async function quickToggleVisible(id,next){
  try{
    await api('PUT',`/api/admin/games/${id}`,{always_visible:next});
    games=await api('GET','/api/admin/games');
    toast(next?'Картка клікабельна на сайті ✓':'Картку заблоковано («скоро») ✓','ok');
    render();
  }catch(e){toast(e.message,'er');}
}
window.quickToggleVisible=quickToggleVisible;

