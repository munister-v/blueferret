function updateTabBadges(){
  $$('.ped-tab').forEach(t=>{
    const tab=t.dataset.tab;if(!tab)return;
    const changes=countTabChanges(tab);
    const cnt=t.querySelector('.tab-cnt');
    if(cnt)cnt.textContent=countTab(tab);
    t.classList.toggle('has-changes',changes>0);
  });
  // update unsaved badge total
  const total=Object.keys(pageEdited).filter(k=>{const b=pageBlocks.find(x=>x.id===k);return b&&pageEdited[k]!==b.value;}).length + deletedBlocks.size + pageBlocks.filter(b=>b.isNew).length;
  const badge=$('#unsaved-badge');if(badge){badge.textContent=total+' змін';badge.classList.toggle('show',total>0);}
}

