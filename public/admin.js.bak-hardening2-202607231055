async function boot(){
  try{
    const ctl=new AbortController();
    const tid=setTimeout(()=>ctl.abort(),12000);
    const me=await fetch('/api/admin/me',{credentials:'same-origin',signal:ctl.signal}).then(r=>r.json()).catch(()=>({authenticated:false})).finally(()=>clearTimeout(tid));
    if(!me.authenticated){showLogin();return;}
    [S,games,kik]=await Promise.all([api('GET','/api/admin/settings'),api('GET','/api/admin/games'),api('GET','/api/admin/kik')]);
    activeTab=loadTab();
    showApp();render();
  }catch(e){
    showLogin();
    const err=$('#loginErr');if(err)err.textContent=e.message||'CMS тимчасово недоступна';
  }
}
boot();