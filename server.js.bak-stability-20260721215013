const sharp = require('sharp');
const upload = multer({
  storage: multer.memoryStorage(),
  limits: { fileSize: 10*1024*1024 },
  fileFilter: (_r, f, cb) => {
    if (!/\.(jpe?g|png|webp|gif|svg|avif)$/i.test(f.originalname)) {
